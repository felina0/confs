// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "enabled_in_text_threads": false,
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "play_sound_when_agent_done": true,
    "default_profile": "write",
    "default_model": {
      // use local ollama model for assistant
      "provider": "copilot_chat",
      "model": "claude-opus-4.7",
    },
  },
  "language_models": {
    "ollama": {
      "available_models": [
        {
          "name": "mistral",
          "display_name": "mistral with tools spongebob with tools",
          "keep_alive": "20m",
          "max_tokens": 10000,
          "supports_tools": true,
        },
        {
          "name": "qwen3:14b",
          "display_name": "qwen3 with tools",
          "keep_alive": "20m",
          "max_tokens": 10000,
          "supports_tools": true,
        },
      ],
    },
  },
  "languages": {
    "Org": {
      "show_edit_predictions": false,
    },
  },
  "show_edit_predictions": true,
  "theme": "Catppuccin Mocha",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "use_smartcase_search": true,
  "vim_mode": true,
  // Vim settings
  "vim": {
    "toggle_relative_line_numbers": false,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 5000,
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
}
